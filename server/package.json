{
  "name": "ashlr-server",
  "version": "0.1.0",
  "description": "ashlr pro-tier backend — Phase 1: hosted badge + stats sync",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "issue-token": "bun run src/cli/issue-token.ts",
    "cap-check": "bun run src/cli/cap-check.ts",
    "email:preview": "bun run src/emails/preview.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/bun": "^10.49.0",
    "hono": "^4.6.0",
    "minimatch": "^10.2.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-email": "^6.0.0",
    "stripe": "^22.0.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.7.0"
  }
}
