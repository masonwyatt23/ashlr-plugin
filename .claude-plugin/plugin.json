{
  "name": "ashlr",
  "version": "1.0.0",
  "description": "Open-source Claude Code plugin — 14 MCP tools (Read/Grep/Edit/MultiEdit/Ask/SQL/Bash/Tree/HTTP/Diff/Logs/Orient/PR+Issue/Glob/WebFetch), per-session token accounting, animated status line, genome auto-refresh, confidence badges, context-pressure widget, shareable SVG savings badge. MIT, zero telemetry.",
  "author": {
    "name": "Mason Wyatt",
    "url": "https://github.com/ashlrai"
  },
  "homepage": "https://plugin.ashlr.ai/",
  "repository": "https://github.com/ashlrai/ashlr-plugin",
  "license": "MIT",
  "keywords": ["claude-code", "plugin", "token-efficiency", "mcp", "ashlrcode", "wozcode-alternative"],
  "statusLine": {
    "type": "command",
    "command": "bun run ${CLAUDE_PLUGIN_ROOT}/scripts/savings-status-line.ts"
  },
  "mcpServers": {
    "ashlr-efficiency": { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/efficiency-server.ts"] },
    "ashlr-sql":        { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/sql-server.ts"] },
    "ashlr-bash":       { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/bash-server.ts"] },
    "ashlr-tree":       { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/tree-server.ts"] },
    "ashlr-http":       { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/http-server.ts"] },
    "ashlr-diff":       { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/diff-server.ts"] },
    "ashlr-logs":       { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/logs-server.ts"] },
    "ashlr-genome":     { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/genome-server.ts"] },
    "ashlr-orient":     { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/orient-server.ts"] },
    "ashlr-github":     { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/github-server.ts"] },
    "ashlr-glob":       { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/glob-server.ts"] },
    "ashlr-webfetch":   { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/webfetch-server.ts"] },
    "ashlr-multi-edit": { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/multi-edit-server.ts"] },
    "ashlr-ask":        { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/ask-server.ts"] },
    "ashlr-diff-semantic": { "command": "bash", "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/mcp-entrypoint.sh", "servers/diff-semantic-server.ts"] }
  }
}
